<div class="flex flex-col gap-3 p-5 items-center">
  <div
    class="
      w-96 bg-neutral-primary-soft border border-default rounded-xl shadow-xs p-4
    "
  >
    <h1 class="flex font-bold justify-center text-4xl pb-2">Teams</h1>
    <ul role="list" class="divide-y divide-teal-100">
      <% @teams.each do |team| %>
        <li
          class="
            flex items-center justify-between hover:bg-cyan-800 px-4 py-2 transition-colors
            hover: cursor-pointer
          "
        >
          <%= link_to team.name, team_path(team), class: "flex-1 py-2 cursor-pointer" %>
        </li>
      <% end %>
    </ul>

  </div>
  <div class="flex justify-center mt-3">
    <%= link_to "New Team",
    new_team_path,
    class:
      "border-2 border-blue-400 px-4 py-2 rounded-4xl text-blue-500 hover:bg-blue-400 hover:text-white" %>
  </div>
</div>

<%# app/views/players/new.html.erb %>
<div class='flex flex-col justify-center justify-self-center w-full max-w-xl'>
  <h1 class="text-3xl pb-3">New Player</h1>

  <div class="flex flex-col py-3">
    <%= render "form", player: @player %>

    <button class="px-4 py-2 my-2 self-center border-2 rounded-4xl">
      <%= link_to "Cancel", team_seasons_path(@season.team_id) %>
    </button>
  </div>
</div>

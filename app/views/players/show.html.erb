<%# app/views/players/show.html.erb %>
<div class="flex flex-col gap-3 p-5 items-center">
  <div
    class="
      w-96 bg-neutral-primary-soft border border-default rounded-xl shadow-xs p-4
    "
  >
    <h1 class="flex font-bold justify-center text-4xl pb-4"><%= @player.name %></h1>
    <div class=" flex items-center justify-between px-4 py-2 ">
      <div class="flex-1">
        Number:
      </div>
      <div class="flex-1">
        <%= @player.jersey_number %>
      </div>

    </div>
    <div class=" flex items-center justify-between px-4 py-2 ">
      <div class="flex-1">
        Active:
      </div>
      <div class="flex-1">
        <%= @player.active %>
      </div>

    </div>

  </div>
  <%= link_to "Edit",
  edit_player_path(@player),
  class:
    "border-2 border-blue-400 px-4 py-2 rounded-4xl text-blue-500 hover:bg-blue-400 hover:text-white" %>
  <%= button_to "Delete",
  @player,
  method: :delete,
  data: {
    turbo_confirm: "Are you sure?",
  },
  class:
    "border-2 border-blue-400 px-4 py-2 rounded-4xl text-blue-500 hover:bg-blue-400 hover:text-white" %>
  <%= link_to "Back",
  players_path,
  class:
    "border-2 border-blue-400 px-4 py-2 rounded-4xl text-blue-500 hover:bg-blue-400 hover:text-white" %>
</div>

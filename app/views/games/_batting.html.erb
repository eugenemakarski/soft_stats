<% max_abs =
  game.plate_appearances.group_by(&:player_id).values.map(&:count).max || 0 %>
<% all_abs = game.plate_appearances %>

<div class="flex flex-col gap-2">
  <div
    id="inning-<%= inn %>"
    class=""
    role="tabpanel"
    aria-labelledby="inning-tab-<%= inn %>"
  >
    <div class="relative overflow-x-auto rounded-base border border-default mt-4">
      <table class="data-table">
        <thead>
          <tr>
            <th class="w-6">#</th>
            <th>Name</th>
            <% (1..max_abs).each do |ab_num| %>
              <th class="text-center">AB<%= ab_num %></th>
            <% end %>
            <th class="text-center w-12"></th>
          </tr>
        </thead>
        <tbody>
          <%# locked if inning_score exists for this inning with our_half %>
          <% inning_locked = game.inning_scores.any? { |s| s.inning == inn && s.our_half? } %>
          <% @rosters.each do |roster| %>
            <% player_abs = all_abs.select { |pa| pa.player_id == roster.player_id }
            is_next = roster.player_id == next_player_id %>
            <tr class="<%= is_next ? 'active-row' : '' %>">
              <td class="text-xs text-body"><%= roster.batting_order %></td>
              <td class="font-medium text-heading whitespace-nowrap"><%= roster.player.name %></td>
              <% (1..max_abs).each do |ab_num| %>
                <td class="text-center">
                  <% pa = player_abs[ab_num - 1] %>
                  <%= pa ? pa_result_chip(pa.result) : "" %>
                </td>
              <% end %>
              <td class="text-center">
                <% if is_next && !inning_locked && active %>
                  <%= link_to "+",
                  new_game_plate_appearance_path(
                    game,
                    inning: inn,
                    top_inning: !@game.is_home,
                    player_id: roster.player_id,
                  ),
                  class:
                    "w-7 h-7 flex items-center justify-center rounded-full bg-brand hover:bg-brand-strong text-white font-bold text-base leading-none mx-auto" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if active %>
      <%= button_to "Next Half Inning →",
      game_inning_scores_path(game),
      method: :post,
      params: {
        inning_score: {
          inning: inn,
          our_half: true,
        },
      },
      class: "btn-outline mt-3 self-start" %>
    <% end %>
  </div>

</div>

<%# app/views/games/show.html.erb %>
<div class="flex flex-col flex-3 gap-3 p-5 items-center">
  <h1 class="font-bold text-4xl"><%= @game.date %>
    vs
    <%= @game.opponent %></h1>
  <% if @game.not_started? %>
    <%= render "pregame", game: @game, rosters: @rosters %>
  <% elsif @game.in_progress? %>
    <%= render "in_progress", game: @game, rosters: @rosters %>
  <% end %>

  <%= link_to "Back",
  season_path(@game.season_id),
  class:
    "border-2 border-blue-400 px-4 py-2 rounded-4xl text-blue-500 hover:bg-blue-400 hover:text-white" %>
  <% if @game.not_started? %>
    <%= link_to "Update Game Roster",
    game_game_rosters_path(@game),
    class:
      "border-2 border-blue-400 px-4 py-2 rounded-4xl text-blue-500 hover:bg-blue-400 hover:text-white" %>
    <%= button_to "START GAME",
    start_game_path(@game),
    method: :patch,
    class:
      "border-2 border-blue-400 mt-4 px-4 py-2 rounded-4xl text-blue-500 hover:bg-blue-400 hover:text-white" %>
  <% end %>
</div>
